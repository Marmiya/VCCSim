#include "/Engine/Public/Platform.ush"

Texture2D<uint2> CustomStencilTexture;

float4 MainPS(float4 SvPosition : SV_POSITION) : SV_Target0
{
    uint2 PixelPos = uint2(SvPosition.xy);
    uint StencilValue = CustomStencilTexture.Load(uint3(PixelPos, 0)).g;

    float NormalizedValue = float(StencilValue) / 255.0;
    return float4(NormalizedValue, NormalizedValue, NormalizedValue, 1.0);
}
