#include "/Engine/Private/Common.ush"

Texture2D InputTexture;
SamplerState InputSampler;

float4 MainPS(float4 SvPosition : SV_POSITION) : SV_Target0
{
    float2 UV = SvPosition.xy * View.BufferSizeAndInvSize.zw;
    float DeviceZ = InputTexture.SampleLevel(InputSampler, UV, 0).r;
    float SceneDepth = ConvertFromDeviceZ(DeviceZ);
    return float4(SceneDepth, SceneDepth, SceneDepth, 1.0);
}
