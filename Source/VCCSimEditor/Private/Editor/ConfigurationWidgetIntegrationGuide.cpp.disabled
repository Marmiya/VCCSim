/**
 * Step 3: Update Configuration Access
 * 
 * Replace direct variable access with widget getters:
 */

/*
// OLD CODE:
void SVCCSimPanel::GeneratePosesAroundTarget()
{
    int32 PoseCount = NumPoses;
    float PoseRadius = Radius;
    // ... use variables directly
}

// NEW CODE:
void SVCCSimPanel::GeneratePosesAroundTarget()
{
    if (PoseConfigWidget.IsValid())
    {
        FPoseConfiguration Config = PoseConfigWidget->GetPoseConfiguration();
        int32 PoseCount = Config.NumPoses;
        float PoseRadius = Config.Radius;
        // ... use configuration struct
    }
}
*/

